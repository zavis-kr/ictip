# ============================================================
# ICTIP — 국제 사이버 위협 인텔리전스 플랫폼
# Environment Variables Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- PostgreSQL Database ---
POSTGRES_USER=ictip
POSTGRES_PASSWORD=ictip_secret          # Change this in production!
POSTGRES_DB=ictip_db

# --- Application Security ---
SECRET_KEY=super_secret_key_change_in_prod  # Change to a long random string in production

# --- External Threat Intelligence API Keys ---
# OTX AlienVault: Get your free key at https://otx.alienvault.com/api
# Leave empty to skip OTX data source (platform will use other sources)
OTX_API_KEY=

# Anthropic Claude API: https://console.anthropic.com/
# Required for AI-powered threat analysis feature
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# --- Application Settings ---
ENVIRONMENT=production          # development | production
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR

# --- Scheduler Intervals ---
FETCH_INTERVAL_MINUTES=5        # How often to fetch new threat intel (minutes)
STATS_UPDATE_INTERVAL_MINUTES=60  # How often to recalculate aggregate stats (minutes)
